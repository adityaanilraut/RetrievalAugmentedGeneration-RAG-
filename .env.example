OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# psycopg3 connection string — adjust user, password, host, port, database
# Homebrew PostgreSQL on macOS often has no "postgres" user; use YOUR username, e.g.:
# DATABASE_URL=postgresql://yourname@localhost:5432/rag
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag
